# LLM Configuration (OpenAI-compatible)
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# Optional: Boost LLM for faster generation
# LLM_BOOST_API_KEY=your_boost_api_key_here
# LLM_BOOST_BASE_URL=your_boost_base_url_here
# LLM_BOOST_MODEL_NAME=your_boost_model_name_here

# Zep Knowledge Graph
ZEP_API_KEY=your_zep_api_key_here

# Nyne People Intelligence API (required for real-people simulation mode)
NYNE_API_KEY=your_nyne_api_key_here
NYNE_API_SECRET=your_nyne_api_secret_here

# Optional Nyne tuning (defaults shown)
# NYNE_MAX_CONCURRENT=10
# NYNE_POLL_INTERVAL=4
# NYNE_POLL_TIMEOUT=500
